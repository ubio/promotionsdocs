:root
  --c-brand #235c6f
  --c-brand-light #2f7f96

.theme-default-content
  line-height 1.6

.theme-default-content h1
  margin-bottom 0.75rem

.theme-default-content h2
  margin-top 2rem

.theme-default-content table
  display table
  width 100%

.theme-default-content pre
  border-radius 6px

.theme-default-content img
  display block
  max-width 100%
  height auto
  margin 1.5rem auto
  border 1px solid #e5e7eb
  border-radius 6px
